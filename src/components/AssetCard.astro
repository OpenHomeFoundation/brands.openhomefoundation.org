---
interface Props {
  title: string;
  mode?: "dark" | "light";
  svg?: string;
  png?: string;
  assetName: string;
}

const { title, mode, svg, png, assetName } = Astro.props;
---

<article class="card sl-flex">
  <div class={`card-asset ${mode ? `card-asset--${mode}` : ""}`}>
    <img src={`/assets/${assetName}.svg`} alt="" class="inline" />
  </div>
  <div class="card-content">
    <p class="title sl-flex">
      <span set:html={title} />
    </p>
    <div class="body"><slot /></div>
    <div class="button-container">
      {
        svg && (
          <a href={svg} class="button" target="_blank">
            SVG
          </a>
        )
      }
      {
        png && (
          <a href={png} class="button" target="_blank">
            PNG
          </a>
        )
      }
    </div>
  </div>
</article>

<style>
  @layer starlight.components {
    .card {
      --sl-card-border: var(--sl-color-purple);
      --sl-card-bg: var(--sl-color-purple-low);
      border: 1px solid var(--sl-color-gray-5);
      background-color: var(--sl-color-black);
      flex-direction: column;
    }
    .card:nth-child(4n + 1) {
      --sl-card-border: var(--sl-color-orange);
      --sl-card-bg: var(--sl-color-orange-low);
    }
    .card:nth-child(4n + 3) {
      --sl-card-border: var(--sl-color-green);
      --sl-card-bg: var(--sl-color-green-low);
    }
    .card:nth-child(4n + 4) {
      --sl-card-border: var(--sl-color-red);
      --sl-card-bg: var(--sl-color-red-low);
    }
    .card:nth-child(4n + 5) {
      --sl-card-border: var(--sl-color-blue);
      --sl-card-bg: var(--sl-color-blue-low);
    }
    .card-asset {
      aspect-ratio: 16/9;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      background-color: #fff;
    }
    .card-asset img {
      max-width: 80%;
    }
    .card-asset--dark {
      background-color: #000;
    }
    .card-content {
      padding: clamp(1rem, calc(0.125rem + 2vw), 2rem);
      margin: 0;
    }
    .title {
      font-weight: 600;
      font-size: var(--sl-text-h4);
      color: var(--sl-color-white);
      line-height: var(--sl-line-height-headings);
      gap: 1rem;
      align-items: center;
      margin-bottom: 1rem;
    }
    .card .body {
      margin: 0;
      font-size: clamp(
        var(--sl-text-sm),
        calc(0.5rem + 1vw),
        var(--sl-text-body)
      );
    }
    .button-container {
      display: flex;
      gap: 1rem;
      margin-top: 1rem;
    }
    .card-content a.button {
      display: block;

      border: 1px solid var(--sl-color-white);
      border-radius: 40px;
      padding: 0.25rem 1rem;
      text-decoration: none;
    }
  }
</style>
